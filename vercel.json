{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "index.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/api/mcp-status",
      "dest": "api/mcp-status.py"
    },
    {
      "src": "/api/web-search",
      "dest": "api/web-search.py"
    },
    {
      "src": "/api/chat",
      "dest": "api/chat.py"
    },
    {
      "src": "/api/chats",
      "dest": "api/chats.py"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai_api_key"
  }
}
